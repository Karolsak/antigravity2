        self.root.geometry("1400x900")
        
        # Style
        self.style = ttk.Style()
        self.style.theme_use('clam')
        self.style.configure('TFrame', background='#f0f0f0')
        self.style.configure('TLabel', font=('Segoe UI', 9))
        self.style.configure('TButton', font=('Segoe UI', 9, 'bold'))
        self.style.configure('Header.TLabel', font=('Segoe UI', 12, 'bold'))
        
        # Parametry - REALISTYCZNE DLA EV
        self.motor_params = {
            'Rs': 0.015,      # Ohm (15 mΩ)
            'Ld': 0.0005,     # H (0.5 mH)
            'Lq': 0.0008,     # H (0.8 mH - większa dla reluctance torque)
            'psi_f': 0.15,    # Wb
            'p': 4,           # 4 pary biegunów = 8 biegunów
            'J': 0.05,        # kg·m² (koło zamachowe + wał)
            'B': 0.01,        # N·m·s/rad (tarcie)
            'P_nom': 150000,  # 150 kW
            'T_nom': 350,     # Nm
            'n_base': 3000    # rpm
        }
        
        self.bat_params = {
            'V_nom': 400,
            'Q_nom': 60,      # kWh
            'SOC_init': 100,
            'R0': 0.03,       # 30 mΩ
            'R1': 0.02,
            'C1': 1000,
            'R2': 0.05,
            'C2': 5000
        }
        
        self.veh_params = {
            'mass': 1500,     # kg
            'Cd': 0.28,       # współczynnik oporu
            'Af': 2.2,        # m² - przekrój czołowy
            'r': 0.315,       # m - promień koła
            'rho': 1.225      # kg/m³ - gęstość powietrza
        }
        
        self.motor = PMSMModel(self.motor_params)
        self.battery = BatteryModel(self.bat_params)
        
        # Zmienne symulacji
