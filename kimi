class PMSMModel:
    """Model PMSM z ograniczeniami dla stabilności numerycznej"""
    def __init__(self, params):
        self.Rs = params.get('Rs', 0.015)  # Ohm - niska rezystancja dla sprawności
        self.Ld = params.get('Ld', 0.0005)  # H (0.5 mH)
        self.Lq = params.get('Lq', 0.0008)  # H (0.8 mH)
        self.psi_f = params.get('psi_f', 0.15)  # Wb
        self.p = params.get('p', 4)  # pary biegunów
        self.J = params.get('J', 0.05)  # kg·m² - moment bezwładności
        self.B = params.get('B', 0.01)  # tarcie wizkotyczne
        
        # Ograniczenia bezpieczeństwa
        self.max_current = 300  # A - maksymalny prąd fazowy
        self.max_omega = 1000  # rad/s (~9550 rpm dla p=4)
        
    def derivatives(self, state, inputs):
        """Stan: [id, iq, omega], Wejścia: [vd, vq, T_L]"""
        id, iq, omega = state
        vd, vq, T_L = inputs
        
        # Ograniczenia stanu (hard limits)
        id = np.clip(id, -self.max_current, self.max_current)
        iq = np.clip(iq, -self.max_current, self.max_current)
        omega = np.clip(omega, -self.max_omega, self.max_omega)
        
        omega_e = omega * self.p  # prędkość elektryczna [rad/s]
        
        # Równania PMSM - układ d-q (Park)
        # di_d/dt = (v_d - R_s*i_d + omega_e*L_q*i_q) / L_d
        did = (vd - self.Rs*id + omega_e*self.Lq*iq) / self.Ld
        
        # di_q/dt = (v_q - R_s*i_q - omega_e*L_d*i_d - omega_e*psi_f) / L_q
        diq = (vq - self.Rs*iq - omega_e*self.Ld*id - omega_e*self.psi_f) / self.Lq
        
        # Moment elektromagnetyczny: T_e = (3/2) * p * [psi_f*i_q + (L_d-L_q)*i_d*i_q]
        Te = 1.5 * self.p * (self.psi_f*iq + (self.Ld - self.Lq)*id*iq)
        
        # Równanie mechaniczne: J*domega/dt = T_e - T_L - B*omega
        domega = (Te - T_L - self.B*omega) / self.J
        
        # Ograniczenie pochodnych (anti-explosion)
        did = np.clip(did, -1e6, 1e6)
        diq = np.clip(diq, -1e6, 1e6)
        domega = np.clip(domega, -500, 500)
        
        return np.array([did, diq, domega]), Te
    
    def get_phase_currents(self, id, iq, theta):
        """Transformacja odwrotna Parka (dq -> abc)"""
        theta_e = theta * self.p
        ia = id * np.cos(theta_e) - iq * np.sin(theta_e)
        ib = id * np.cos(theta_e - 2.094) - iq * np.sin(theta_e - 2.094)
        ic = -(ia + ib)  # i_a + i_b + i_c = 0 dla układu bezprzewodowego
        return ia, ib, ic


class BatteryModel:
    """Model baterii z zabezpieczeniem przed przeładowaniem"""
    def __init__(self, params):
        self.Q_nom = params.get('Q_nom', 60) * 3600  # kWh -> Coulombs (60Ah * 3600)
        self.R0 = params.get('R0', 0.03)  # Ohm - rezystancja wewnętrzna
        self.R1 = params.get('R1', 0.02)
        self.C1 = params.get('C1', 1000)
        self.R2 = params.get('R2', 0.05)
        self.C2 = params.get('C2', 5000)
        self.eta = params.get('eta', 0.99)  # sprawność Coulomba
        
    def ocv(self, soc):
        """Napięcie jałowe - ograniczone do fizycznych wartości"""
        soc = np.clip(soc, 0, 100)
        return 3.2 + 0.8*(soc/100) + 0.1*np.sin((soc/100)*np.pi)
    
    def derivatives(self, state, I):
        """Stan: [SOC, Vc1, Vc2]"""
        soc, vc1, vc2 = state
        
        # Ograniczenia
        soc = np.clip(soc, 0, 100)
        I = np.clip(I, -300, 300)  # max 300A charge/discharge
        
        dvc1 = (I/self.C1) - (vc1/(self.R1*self.C1))
        dvc2 = (I/self.C2) - (vc2/(self.R2*self.C2))
        dsoc = -(I * self.eta) / (self.Q_nom) * 100  # % na sekundę
        
        V_bat = 400 * self.ocv(soc)/4.0 - I*self.R0 - vc1 - vc2  # skalowanie do 400V
        V_bat = np.clip(V_bat, 250, 450)  # realistyczny zakres Li-ion
        
        return np.array([dsoc, dvc1, dvc2]), V_bat


class EVDriveLabApp:
