        self.veh_mass.grid(row=0, column=1, padx=5)
        
        ttk.Label(veh_frame, text='Cx:').grid(row=1, column=0, sticky='w')
        self.veh_cd = ttk.Spinbox(veh_frame, from_=0.20, to=0.45, increment=0.01)
        self.veh_cd.set(0.28)
