    def update_motor_params(self):
        """Aktualizacja parametrów silnika z UI"""
        try:
            self.motor_params['Rs'] = float(self.motor_entries['mot_rs'].get()) / 1000  # mΩ -> Ω
            self.motor_params['Ld'] = float(self.motor_entries['mot_ld'].get()) / 1000   # mH -> H
            self.motor_params['Lq'] = float(self.motor_entries['mot_lq'].get()) / 1000
            self.motor_params['psi_f'] = float(self.motor_entries['mot_psi'].get())
            self.motor_params['p'] = int(self.motor_entries['mot_p'].get())
            self.motor_params['J'] = float(self.motor_entries['mot_j'].get())
            
            self.motor = PMSMModel(self.motor_params)
            self.update_motor_curves()
            messagebox.showinfo('OK', 'Parametry zastosowane')
        except Exception as e:
            messagebox.showerror('Błąd', str(e))
            
    def update_motor_curves(self):
        """Obliczenie i wyświetlenie charakterystyk"""
        n_max = 10000  # rpm
        n_points = np.linspace(0, n_max, 200)
        
        torques = []
        powers = []
        
        p = self.motor_params
        T_nom = p['T_nom']
        n_base = p['n_base']
        P_nom = p['P_nom']
        
        for n in n_points:
            if n <= n_base:
                T = T_nom
            else:
                T = (P_nom * 1000) / (n * 2 * np.pi / 60)  # P = T * omega
            if n > 8000:
                T *= 0.8  # field weakening drop
            
            T = max(0, T)
            torques.append(T)
            powers.append(T * n / 9550)
        
        self.ax_torque.clear()
        self.ax_power.clear()
        
        self.ax_torque.plot(n_points, torques, 'b-', linewidth=2, label='Moment')
        self.ax_torque.set_ylabel('Moment [Nm]', color='blue')
        self.ax_torque.tick_params(axis='y', labelcolor='blue')
        self.ax_torque.set_xlabel('Prędkość [rpm]')
        self.ax_torque.grid(True)
        
        self.ax_power.plot(n_points, powers, 'r-', linewidth=2, label='Moc')
        self.ax_power.set_ylabel('Moc [kW]', color='red')
        self.ax_power.tick_params(axis='y', labelcolor='red')
        
        self.ax_torque.set_title('Charakterystyka Moment-Prędkość')
        self.canvas_motor.draw()
        
    def start_simulation(self):
        if self.sim_running:
            return
            
        self.sim_running = True
        self.status_var.set('Symulacja w toku...')
        
        thread = threading.Thread(target=self.simulation_loop)
        thread.daemon = True
        thread.start()
        
    def stop_simulation(self):
        self.sim_running = False
        self.status_var.set('Zatrzymano')
        
    def simulation_loop(self):
        """Główna pętla symulacji z zabezpieczeniami"""
        dt = self.dt_var.get() / 1000.0  # ms -> s (0.1ms domyślnie!)
        duration = self.duration_var.get()
        
        # Inicjalizacja stanów
        # [id, iq, omega_mech, theta]
        motor_state = np.array([0.0, 0.0, 0.0, 0.0])
        bat_state = np.array([100.0, 0.0, 0.0])  # [SOC, Vc1, Vc2]
        
        # Dane do wykresów
        times = []
        speeds = []
        torques = []
        currents = []
        
        # Regulatory PI z anti-windup
        error_int = 0.0
        max_error_int = 1000.0  # ograniczenie calkowania błędu
        
        t = 0.0
        step = 0
        
        try:
            while self.sim_running and t < duration:
                # Profil prędkości referencyjnej (0 -> 80 km/h -> stop)
                if t < 2:
                    v_ref = t * 40  # 0-80 km/h w 2s
                elif t < 4:
                    v_ref = 80
                else:
                    v_ref = max(0, 80 - (t-4)*40)  # hamowanie
                
                # Konwersja do rad/s (KLUCZOWE: v[m/s] / r[m] = omega[rad/s])
                v_ms = v_ref / 3.6
                omega_ref = v_ms / self.veh_params['r']
                
                # PI controller (speed) z ograniczeniem
                omega_mech = motor_state[2]
                error = omega_ref - omega_mech
                error_int = np.clip(error_int + error * dt, -max_error_int, max_error_int)
                
                Kp = 50.0  # wzmocnienie proporcjonalne
                Ki = 5.0   # wzmocnienie całkujące
                
                iq_ref = Kp * error + Ki * error_int
                iq_ref = np.clip(iq_ref, -300, 300)  # ograniczenie prądu
                
                # Id = 0 control (MTPA - Maximum Torque Per Ampere)
                id_ref = 0.0
                
                # Proste sterowanie prądem (tłumienie)
                vd = 0.5 * (id_ref - motor_state[0])
                vq = 0.5 * (iq_ref - motor_state[1])
                
                # Ograniczenie napięcia (modulacja)
                v_max = self.bat_params['V_nom'] / np.sqrt(3)  # max napięcie fazowe
                v_mag = np.sqrt(vd**2 + vq**2)
                if v_mag > v_max:
                    vd = vd * v_max / v_mag
                    vq = vq * v_max / v_mag
                
                # Obliczenie obciążenia (aerodynamika + tarcie)
                v_veh = omega_mech * self.veh_params['r']
                F_aero = 0.5 * self.veh_params['rho'] * self.veh_params['Cd'] * self.veh_params['Af'] * v_veh**2
                F_roll = 0.01 * self.veh_params['mass'] * 9.81
                T_load = (F_aero + F_roll) * self.veh_params['r']
                
                # RK4 integration with safety checks
                def motor_ode(y):
                    dydt, _ = self.motor.derivatives(y[:3], [vd, vq, T_load])
                    # dtheta/dt = omega
                    return np.array([dydt[0], dydt[1], dydt[2], y[2]])
                
                # RK4 step
                k1 = motor_ode(motor_state)
                k2 = motor_ode(motor_state + 0.5*dt*k1)
                k3 = motor_ode(motor_state + 0.5*dt*k2)
                k4 = motor_ode(motor_state + dt*k3)
                
                motor_new = motor_state + (dt/6.0) * (k1 + 2*k2 + 2*k3 + k4)
                
                # Hard limits po integracji
                motor_new[0] = np.clip(motor_new[0], -300, 300)  # id
                motor_new[1] = np.clip(motor_new[1], -300, 300)  # iq
                motor_new[2] = np.clip(motor_new[2], -1000, 1000) # omega (rad/s)
                
                # Sprawdzenie NaN/Inf
                if np.any(np.isnan(motor_new)) or np.any(np.isinf(motor_new)):
                    raise ValueError("Numerical instability detected!")
                
                motor_state = motor_new
                
                # Model baterii (uproszczony - tylko SOC)
                Te = 1.5 * self.motor_params['p'] * self.motor_params['psi_f'] * motor_state[1]
                P_mech = Te * motor_state[2]
                I_bat = P_mech / (self.bat_params['V_nom'] * 0.95)  # przybliżony prąd
                I_bat = np.clip(I_bat, -300, 300)
                
                dsoc = -(I_bat * 0.99) / (self.bat_params['Q_nom'] * 3600) * 100 * dt
                bat_state[0] = np.clip(bat_state[0] + dsoc, 0, 100)
                
                # Zapisywanie danych (co 10 kroków dla wydajności)
                if step % 10 == 0:
                    times.append(t)
                    speeds.append(motor_state[2] * self.veh_params['r'] * 3.6)  # km/h
                    torques.append(Te)
                    currents.append(np.sqrt(motor_state[0]**2 + motor_state[1]**2))
                    
                    # Aktualizacja UI (co 100 kroków aby nie zamulać)
                    if step % 100 == 0 and len(times) > 1:
                        self.root.after(0, self.update_sim_plots, times[:], speeds[:], torques[:], currents[:])
                
                t += dt
                step += 1
                
                # Małe opóźnienie aby nie blokować UI (symulacja wolniejsza niż rzeczywistość dla widoczności)
                if step % 100 == 0:
                    time.sleep(0.001)
                    
        except Exception as e:
            self.root.after(0, lambda: messagebox.showerror('Błąd symulacji', f'Wystąpił błąd numeryczny:\n{str(e)}\n\nSprawdź parametry silnika i zmniejsz krok czasowy.'))
            
        finally:
            self.sim_running = False
            self.root.after(0, lambda: self.status_var.set('Zakończono'))
            
    def update_sim_plots(self, times, speeds, torques, currents):
        """Aktualizacja wykresów"""
        self.ax_sim1.clear()
        self.ax_sim1.plot(times, speeds, 'b-', linewidth=2)
        self.ax_sim1.set_ylabel('Prędkość [km/h]')
        self.ax_sim1.grid(True)
        
        self.ax_sim2.clear()
        self.ax_sim2.plot(times, torques, 'r-', linewidth=2)
        self.ax_sim2.set_ylabel('Moment [Nm]')
        self.ax_sim2.grid(True)
        
        self.ax_sim3.clear()
        self.ax_sim3.plot(times, currents, 'g-', linewidth=2)
        self.ax_sim3.set_ylabel('Prąd [A]')
        self.ax_sim3.set_xlabel('Czas [s]')
        self.ax_sim3.grid(True)
        
        self.fig_sim.tight_layout()
        self.canvas_sim.draw()


